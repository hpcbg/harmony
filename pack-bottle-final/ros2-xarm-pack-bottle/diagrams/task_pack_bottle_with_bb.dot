digraph pastafarianism {
ordering=out;
graph [fontname="times-roman"];
node [fontname="times-roman"];
edge [fontname="times-roman"];
"Task Pack Bottle" [fillcolor=gold, fontcolor=black, fontsize=9, label="Task Pack Bottle\nSuccessOnAll", shape=parallelogram, style=filled];
"System Monitor" [fillcolor=orange, fontcolor=black, fontsize=9, label="Ⓜ System Monitor", shape=box, style=filled];
"Task Pack Bottle" -> "System Monitor";
"Report Status" [fillcolor=gray, fontcolor=black, fontsize=9, label="Report Status", shape=ellipse, style=filled];
"System Monitor" -> "Report Status";
"Bottle Detector Status" [fillcolor=gray, fontcolor=black, fontsize=9, label="Bottle Detector Status", shape=ellipse, style=filled];
"System Monitor" -> "Bottle Detector Status";
"User Requests Monitor" [fillcolor=gray, fontcolor=black, fontsize=9, label="User Requests Monitor", shape=ellipse, style=filled];
"System Monitor" -> "User Requests Monitor";
Workflow [fillcolor=cyan, fontcolor=black, fontsize=9, label="Ⓜ Workflow", shape=octagon, style=filled];
"Task Pack Bottle" -> Workflow;
Detect [fillcolor=orange, fontcolor=black, fontsize=9, label="Ⓜ Detect", shape=box, style=filled];
Workflow -> Detect;
"Pick Requested?" [fillcolor=gray, fontcolor=black, fontsize=9, label="Pick Requested?", shape=ellipse, style=filled];
Detect -> "Pick Requested?";
"Run Bottle Detection" [fillcolor=gray, fontcolor=black, fontsize=9, label="Run Bottle Detection", shape=ellipse, style=filled];
Detect -> "Run Bottle Detection";
Pick [fillcolor=orange, fontcolor=black, fontsize=9, label="Ⓜ Pick", shape=box, style=filled];
Workflow -> Pick;
"Bottle Detected?" [fillcolor=gray, fontcolor=black, fontsize=9, label="Bottle Detected?", shape=ellipse, style=filled];
Pick -> "Bottle Detected?";
"Run Pick" [fillcolor=gray, fontcolor=black, fontsize=9, label="Run Pick", shape=ellipse, style=filled];
Pick -> "Run Pick";
"Go to Fill" [fillcolor=orange, fontcolor=black, fontsize=9, label="Ⓜ Go to Fill", shape=box, style=filled];
Workflow -> "Go to Fill";
"Pick Ready?" [fillcolor=gray, fontcolor=black, fontsize=9, label="Pick Ready?", shape=ellipse, style=filled];
"Go to Fill" -> "Pick Ready?";
"Move to Fill" [fillcolor=gray, fontcolor=black, fontsize=9, label="Move to Fill", shape=ellipse, style=filled];
"Go to Fill" -> "Move to Fill";
"Go to Cap" [fillcolor=orange, fontcolor=black, fontsize=9, label="Ⓜ Go to Cap", shape=box, style=filled];
Workflow -> "Go to Cap";
"Fill Completed?" [fillcolor=gray, fontcolor=black, fontsize=9, label="Fill Completed?", shape=ellipse, style=filled];
"Go to Cap" -> "Fill Completed?";
"Move to Cap" [fillcolor=gray, fontcolor=black, fontsize=9, label="Move to Cap", shape=ellipse, style=filled];
"Go to Cap" -> "Move to Cap";
Cap [fillcolor=orange, fontcolor=black, fontsize=9, label="Ⓜ Cap", shape=box, style=filled];
Workflow -> Cap;
"Cap Requested?" [fillcolor=gray, fontcolor=black, fontsize=9, label="Cap Requested?", shape=ellipse, style=filled];
Cap -> "Cap Requested?";
"Start Cap" [fillcolor=gray, fontcolor=black, fontsize=9, label="Start Cap", shape=ellipse, style=filled];
Cap -> "Start Cap";
Handover [fillcolor=orange, fontcolor=black, fontsize=9, label="Ⓜ Handover", shape=box, style=filled];
Workflow -> Handover;
"Handover Requested?" [fillcolor=gray, fontcolor=black, fontsize=9, label="Handover Requested?", shape=ellipse, style=filled];
Handover -> "Handover Requested?";
"Start Handover" [fillcolor=gray, fontcolor=black, fontsize=9, label="Start Handover", shape=ellipse, style=filled];
Handover -> "Start Handover";
"Finish Task" [fillcolor=orange, fontcolor=black, fontsize=9, label="Ⓜ Finish Task", shape=box, style=filled];
Workflow -> "Finish Task";
"Handover Executed?" [fillcolor=gray, fontcolor=black, fontsize=9, label="Handover Executed?", shape=ellipse, style=filled];
"Finish Task" -> "Handover Executed?";
"Finish Pack Bottle" [fillcolor=gray, fontcolor=black, fontsize=9, label="Finish Pack Bottle", shape=ellipse, style=filled];
"Finish Task" -> "Finish Pack Bottle";
"Idle Status" [fillcolor=gray, fontcolor=black, fontsize=9, label="Idle Status", shape=ellipse, style=filled];
Workflow -> "Idle Status";
"/status" -> "Report Status"  [color=green, constraint=False, weight=0];
"Run Bottle Detection" -> "/status"  [color=blue, constraint=False, weight=0];
"Start Cap" -> "/status"  [color=blue, constraint=False, weight=0];
"Start Handover" -> "/status"  [color=blue, constraint=False, weight=0];
"Bottle Detector Status" -> "/status"  [color=blue, constraint=False, weight=0];
"Run Pick" -> "/status"  [color=blue, constraint=False, weight=0];
"Finish Pack Bottle" -> "/status"  [color=blue, constraint=False, weight=0];
"Move to Fill" -> "/status"  [color=blue, constraint=False, weight=0];
"User Requests Monitor" -> "/status"  [color=blue, constraint=False, weight=0];
"Idle Status" -> "/status"  [color=blue, constraint=False, weight=0];
"Move to Cap" -> "/status"  [color=blue, constraint=False, weight=0];
"/pick_pose" -> "Run Pick"  [color=green, constraint=False, weight=0];
"Bottle Detector Status" -> "/pick_pose"  [color=blue, constraint=False, weight=0];
"/stage" -> "Handover Requested?"  [color=green, constraint=False, weight=0];
"/stage" -> "Cap Requested?"  [color=green, constraint=False, weight=0];
"/stage" -> "Handover Executed?"  [color=green, constraint=False, weight=0];
"/stage" -> "Fill Completed?"  [color=green, constraint=False, weight=0];
"/stage" -> "Pick Ready?"  [color=green, constraint=False, weight=0];
"/stage" -> "Bottle Detected?"  [color=green, constraint=False, weight=0];
"/stage" -> "Idle Status"  [color=green, constraint=False, weight=0];
"/stage" -> "Pick Requested?"  [color=green, constraint=False, weight=0];
"Run Bottle Detection" -> "/stage"  [color=blue, constraint=False, weight=0];
"Start Cap" -> "/stage"  [color=blue, constraint=False, weight=0];
"Start Handover" -> "/stage"  [color=blue, constraint=False, weight=0];
"Bottle Detector Status" -> "/stage"  [color=blue, constraint=False, weight=0];
"Run Pick" -> "/stage"  [color=blue, constraint=False, weight=0];
"Finish Pack Bottle" -> "/stage"  [color=blue, constraint=False, weight=0];
"Move to Fill" -> "/stage"  [color=blue, constraint=False, weight=0];
"User Requests Monitor" -> "/stage"  [color=blue, constraint=False, weight=0];
"Move to Cap" -> "/stage"  [color=blue, constraint=False, weight=0];
"Handover Requested?" -> "/prev_stage"  [color=blue, constraint=False, weight=0];
"Cap Requested?" -> "/prev_stage"  [color=blue, constraint=False, weight=0];
"Handover Executed?" -> "/prev_stage"  [color=blue, constraint=False, weight=0];
"Fill Completed?" -> "/prev_stage"  [color=blue, constraint=False, weight=0];
"Pick Ready?" -> "/prev_stage"  [color=blue, constraint=False, weight=0];
"Bottle Detected?" -> "/prev_stage"  [color=blue, constraint=False, weight=0];
"Pick Requested?" -> "/prev_stage"  [color=blue, constraint=False, weight=0];
subgraph Blackboard {
id=Blackboard;
label=Blackboard;
rank=sink;
"Report Status" [color=blue, fillcolor=gray, fontcolor=blue, fontsize=7, label="Report Status", shape=ellipse, style=filled];
"Bottle Detector Status" [color=blue, fillcolor=gray, fontcolor=blue, fontsize=7, label="Bottle Detector Status", shape=ellipse, style=filled];
"User Requests Monitor" [color=blue, fillcolor=gray, fontcolor=blue, fontsize=7, label="User Requests Monitor", shape=ellipse, style=filled];
"Run Bottle Detection" [color=blue, fillcolor=gray, fontcolor=blue, fontsize=7, label="Run Bottle Detection", shape=ellipse, style=filled];
"Pick Requested?" [color=blue, fillcolor=gray, fontcolor=blue, fontsize=7, label="Pick Requested?", shape=ellipse, style=filled];
"Run Pick" [color=blue, fillcolor=gray, fontcolor=blue, fontsize=7, label="Run Pick", shape=ellipse, style=filled];
"Bottle Detected?" [color=blue, fillcolor=gray, fontcolor=blue, fontsize=7, label="Bottle Detected?", shape=ellipse, style=filled];
"Move to Fill" [color=blue, fillcolor=gray, fontcolor=blue, fontsize=7, label="Move to Fill", shape=ellipse, style=filled];
"Pick Ready?" [color=blue, fillcolor=gray, fontcolor=blue, fontsize=7, label="Pick Ready?", shape=ellipse, style=filled];
"Move to Cap" [color=blue, fillcolor=gray, fontcolor=blue, fontsize=7, label="Move to Cap", shape=ellipse, style=filled];
"Fill Completed?" [color=blue, fillcolor=gray, fontcolor=blue, fontsize=7, label="Fill Completed?", shape=ellipse, style=filled];
"Start Cap" [color=blue, fillcolor=gray, fontcolor=blue, fontsize=7, label="Start Cap", shape=ellipse, style=filled];
"Cap Requested?" [color=blue, fillcolor=gray, fontcolor=blue, fontsize=7, label="Cap Requested?", shape=ellipse, style=filled];
"Start Handover" [color=blue, fillcolor=gray, fontcolor=blue, fontsize=7, label="Start Handover", shape=ellipse, style=filled];
"Handover Requested?" [color=blue, fillcolor=gray, fontcolor=blue, fontsize=7, label="Handover Requested?", shape=ellipse, style=filled];
"Finish Pack Bottle" [color=blue, fillcolor=gray, fontcolor=blue, fontsize=7, label="Finish Pack Bottle", shape=ellipse, style=filled];
"Handover Executed?" [color=blue, fillcolor=gray, fontcolor=blue, fontsize=7, label="Handover Executed?", shape=ellipse, style=filled];
"Idle Status" [color=blue, fillcolor=gray, fontcolor=blue, fontsize=7, label="Idle Status", shape=ellipse, style=filled];
"/status" [color=blue, fillcolor=white, fixedsize=False, fontcolor=blue, fontsize=8, height=0, label="/status: -", shape=box, style=filled, width=0];
"/pick_pose" [color=blue, fillcolor=white, fixedsize=False, fontcolor=blue, fontsize=8, height=0, label="/pick_pose: {}", shape=box, style=filled, width=0];
"/stage" [color=blue, fillcolor=white, fixedsize=False, fontcolor=blue, fontsize=8, height=0, label="/stage: -", shape=box, style=filled, width=0];
"/prev_stage" [color=blue, fillcolor=white, fixedsize=False, fontcolor=blue, fontsize=8, height=0, label="/prev_stage: -", shape=box, style=filled, width=0];
}

}
