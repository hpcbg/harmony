digraph pastafarianism {
ordering=out;
graph [fontname="times-roman"];
node [fontname="times-roman"];
edge [fontname="times-roman"];
"Task Pack Bottle" [fillcolor=gold, fontcolor=black, fontsize=9, label="Task Pack Bottle\nSuccessOnAll", shape=parallelogram, style=filled];
"System Monitor" [fillcolor=orange, fontcolor=black, fontsize=9, label="Ⓜ System Monitor", shape=box, style=filled];
"Task Pack Bottle" -> "System Monitor";
"Report Status" [fillcolor=gray, fontcolor=black, fontsize=9, label="Report Status", shape=ellipse, style=filled];
"System Monitor" -> "Report Status";
"Bottle Detector Status" [fillcolor=gray, fontcolor=black, fontsize=9, label="Bottle Detector Status", shape=ellipse, style=filled];
"System Monitor" -> "Bottle Detector Status";
"User Requests Monitor" [fillcolor=gray, fontcolor=black, fontsize=9, label="User Requests Monitor", shape=ellipse, style=filled];
"System Monitor" -> "User Requests Monitor";
Workflow [fillcolor=cyan, fontcolor=black, fontsize=9, label="Ⓜ Workflow", shape=octagon, style=filled];
"Task Pack Bottle" -> Workflow;
Detect [fillcolor=orange, fontcolor=black, fontsize=9, label="Ⓜ Detect", shape=box, style=filled];
Workflow -> Detect;
"Pick Requested?" [fillcolor=gray, fontcolor=black, fontsize=9, label="Pick Requested?", shape=ellipse, style=filled];
Detect -> "Pick Requested?";
"Run Bottle Detection" [fillcolor=gray, fontcolor=black, fontsize=9, label="Run Bottle Detection", shape=ellipse, style=filled];
Detect -> "Run Bottle Detection";
Pick [fillcolor=orange, fontcolor=black, fontsize=9, label="Ⓜ Pick", shape=box, style=filled];
Workflow -> Pick;
"Bottle Detected?" [fillcolor=gray, fontcolor=black, fontsize=9, label="Bottle Detected?", shape=ellipse, style=filled];
Pick -> "Bottle Detected?";
"Run Pick" [fillcolor=gray, fontcolor=black, fontsize=9, label="Run Pick", shape=ellipse, style=filled];
Pick -> "Run Pick";
"Go to Fill" [fillcolor=orange, fontcolor=black, fontsize=9, label="Ⓜ Go to Fill", shape=box, style=filled];
Workflow -> "Go to Fill";
"Pick Ready?" [fillcolor=gray, fontcolor=black, fontsize=9, label="Pick Ready?", shape=ellipse, style=filled];
"Go to Fill" -> "Pick Ready?";
"Move to Fill" [fillcolor=gray, fontcolor=black, fontsize=9, label="Move to Fill", shape=ellipse, style=filled];
"Go to Fill" -> "Move to Fill";
"Go to Cap" [fillcolor=orange, fontcolor=black, fontsize=9, label="Ⓜ Go to Cap", shape=box, style=filled];
Workflow -> "Go to Cap";
"Fill Completed?" [fillcolor=gray, fontcolor=black, fontsize=9, label="Fill Completed?", shape=ellipse, style=filled];
"Go to Cap" -> "Fill Completed?";
"Move to Cap" [fillcolor=gray, fontcolor=black, fontsize=9, label="Move to Cap", shape=ellipse, style=filled];
"Go to Cap" -> "Move to Cap";
Cap [fillcolor=orange, fontcolor=black, fontsize=9, label="Ⓜ Cap", shape=box, style=filled];
Workflow -> Cap;
"Cap Requested?" [fillcolor=gray, fontcolor=black, fontsize=9, label="Cap Requested?", shape=ellipse, style=filled];
Cap -> "Cap Requested?";
"Start Cap" [fillcolor=gray, fontcolor=black, fontsize=9, label="Start Cap", shape=ellipse, style=filled];
Cap -> "Start Cap";
Handover [fillcolor=orange, fontcolor=black, fontsize=9, label="Ⓜ Handover", shape=box, style=filled];
Workflow -> Handover;
"Handover Requested?" [fillcolor=gray, fontcolor=black, fontsize=9, label="Handover Requested?", shape=ellipse, style=filled];
Handover -> "Handover Requested?";
"Start Handover" [fillcolor=gray, fontcolor=black, fontsize=9, label="Start Handover", shape=ellipse, style=filled];
Handover -> "Start Handover";
"Finish Task" [fillcolor=orange, fontcolor=black, fontsize=9, label="Ⓜ Finish Task", shape=box, style=filled];
Workflow -> "Finish Task";
"Handover Executed?" [fillcolor=gray, fontcolor=black, fontsize=9, label="Handover Executed?", shape=ellipse, style=filled];
"Finish Task" -> "Handover Executed?";
"Finish Pack Bottle" [fillcolor=gray, fontcolor=black, fontsize=9, label="Finish Pack Bottle", shape=ellipse, style=filled];
"Finish Task" -> "Finish Pack Bottle";
"Idle Status" [fillcolor=gray, fontcolor=black, fontsize=9, label="Idle Status", shape=ellipse, style=filled];
Workflow -> "Idle Status";
}
